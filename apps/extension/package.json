{
  "name": "ai-coding-devtool-extension",
  "displayName": "DevPilot",
  "description": "AI coding workflows for VS Code.",
  "version": "0.1.0",
  "publisher": "devpilot-local",
  "repository": {
    "type": "git",
    "url": "https://github.com/XingYiLiii/ai-coding-devtool-plugin.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devpilot.explainCode",
        "category": "DevPilot",
        "title": "Explain Selected Code"
      },
      {
        "command": "devpilot.generatePlan",
        "category": "DevPilot",
        "title": "Generate Development Plan"
      },
      {
        "command": "devpilot.generateCommitMessage",
        "category": "DevPilot",
        "title": "Generate Commit Message"
      },
      {
        "command": "devpilot.reviewChanges",
        "category": "DevPilot",
        "title": "Review Staged Changes"
      }
    ],
    "configuration": {
      "title": "DevPilot",
      "properties": {
        "devpilot.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL for the local DevPilot backend."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npm run compile && node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && vsce package --out dist/devpilot.vsix",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --max-warnings=0",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "compile:test": "tsc -p tsconfig.test.json",
    "test": "npm run compile:test && node --test out/test/backend-client.test.js && node --test out/test/backend-health.test.js && node --test out/test/explain-code-command.test.js && node --test out/test/generate-plan-command.test.js && node --test out/test/git-context.test.js && node --test out/test/git-workflow-commands.test.js && node --test out/test/user-messages.test.js && node --test out/test/output-format.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  }
}
