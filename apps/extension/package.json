{
  "name": "ai-coding-devtool-extension",
  "displayName": "AI Coding Devtool",
  "description": "VS Code extension for ai-coding-devtool-plugin.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --max-warnings=0",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "compile:test": "tsc -p tsconfig.test.json",
    "test": "npm run compile:test && node --test out/test/backend-client.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.95.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  }
}
